/**
 * Finda - Architecture Model
 *
 * Defines all system elements and their relationships.
 * Finda ingests bank statements (text or image), parses and classifies
 * transactions, stores them in a unified database, and exposes them
 * for reporting and analytics.
 */

model {

  // ─── Actors ───────────────────────────────────────────────────────────────

  user = person 'User' {
    description 'Personal finance owner who uploads bank statements and reviews categorized transactions'
  }

  // ─── External Systems ─────────────────────────────────────────────────────

  bankSource = external 'Bank Statement Source' {
    description 'Upstream bank portals or local exports providing statements in PDF, CSV, plain text, or image formats'
  }

  // ─── Finda System ─────────────────────────────────────────────────────────

  finda = system 'Finda' {
    description 'Personal bank account data pipeline: ingest, parse, classify, store, and process bank statements'

    // ── Web Application ──────────────────────────────────────────────────

    webApp = service 'Web App' {
      description 'Browser-based dashboard allowing the user to upload statements, browse transactions, review categories, and view analytics reports'
    }

    // ── Ingestion ────────────────────────────────────────────────────────

    ingestionService = service 'Ingestion Service' {
      description 'Entry point for uploaded statement files. Detects format (image vs. text/CSV/PDF), routes to the appropriate parser, and coordinates the processing pipeline'

      fileReceiver = service 'File Receiver' {
        description 'Accepts incoming statement files from the Web App, CLI, or a direct bank source feed. Validates that the file is readable and stores it temporarily for processing'
      }

      formatDetector = service 'Format Detector' {
        description 'Inspects each file via MIME type, magic bytes, and extension to classify it as an image, PDF, CSV, or plain-text statement'
      }

      routingCoordinator = service 'Routing Coordinator' {
        description 'Dispatches the classified file along the correct path: image files go to the OCR Engine; text-based files (PDF, CSV, plain text) go directly to the Parser Service'
      }
    }

    ocrEngine = service 'OCR Engine' {
      description 'Converts image-based bank statements (scanned pages, photos) into machine-readable text using optical character recognition'
    }

    parserService = service 'Parser Service' {
      description 'Extracts structured transaction records (date, amount, description, currency, account) from raw text or CSV/PDF content'
    }

    // ── Classification ───────────────────────────────────────────────────

    classificationEngine = service 'Classification Engine' {
      description 'Assigns each transaction to an income or expense category (e.g. Groceries, Rent, Salary) using rules and/or ML-based classification'
    }

    // ── Storage ──────────────────────────────────────────────────────────

    storageService = service 'Storage Service' {
      description 'Persists classified transactions and manages the unified data schema. Provides a query API for other services'
    }

    transactionDb = store 'Transaction DB' {
      description 'Unified relational store for all parsed and classified transaction records across all accounts and banks'
    }

    categoryDb = store 'Category DB' {
      description 'Reference store for the expense/income taxonomy: category names, keywords, classification rules, and ML model metadata'
    }

    // ── Analytics ────────────────────────────────────────────────────────

    analyticsService = service 'Analytics Service' {
      description 'Aggregates stored transactions to produce spending summaries, income trends, budget comparisons, and exportable reports'
    }

    // ── CLI ──────────────────────────────────────────────────────────────

    cliApp = service 'CLI' {
      description 'Command-line interface for running Finda in automated jobs and scheduled pipelines. Reads a configuration file to locate statement sources, trigger ingestion, and optionally export analytics reports without human interaction'
    }

  }

  // ─── Relationships ────────────────────────────────────────────────────────

  // User interactions
  user -> finda.webApp 'uploads statements, reviews transactions and reports'
  bankSource -> finda.ingestionService 'provides statement files (PDF, CSV, image, text)'

  // Ingestion pipeline (high-level, used by container and flow views)
  finda.webApp -> finda.ingestionService 'submits uploaded statement file'
  finda.ingestionService -> finda.ocrEngine 'sends image statement for text extraction'
  finda.ingestionService -> finda.parserService 'sends text/CSV/PDF content for parsing'
  finda.ocrEngine -> finda.parserService 'passes extracted raw text'

  // Ingestion Service internals (used by the ingestion_service detail view)
  finda.webApp -> finda.ingestionService.fileReceiver 'submits uploaded file'
  finda.cliApp -> finda.ingestionService.fileReceiver 'submits statement file from configured source'
  bankSource -> finda.ingestionService.fileReceiver 'provides statement file directly'
  finda.ingestionService.fileReceiver -> finda.ingestionService.formatDetector 'passes file for format inspection'
  finda.ingestionService.formatDetector -> finda.ingestionService.routingCoordinator 'forwards classified file'
  finda.ingestionService.routingCoordinator -> finda.ocrEngine 'routes image file for OCR'
  finda.ingestionService.routingCoordinator -> finda.parserService 'routes text/CSV/PDF for parsing'

  // Classification pipeline
  finda.parserService -> finda.classificationEngine 'sends structured transaction records'
  finda.classificationEngine -> finda.categoryDb 'reads category rules and taxonomy'
  finda.classificationEngine -> finda.storageService 'sends classified transactions'

  // Storage
  finda.storageService -> finda.transactionDb 'reads and writes transaction records'

  // Analytics
  finda.analyticsService -> finda.storageService 'queries transaction data'
  finda.webApp -> finda.analyticsService 'requests reports and summaries'

  // CLI (automated jobs)
  user -> finda.cliApp 'configures and invokes automated jobs'
  bankSource -> finda.cliApp 'provides statement files for batch processing'
  finda.cliApp -> finda.ingestionService 'submits statement files from configured sources'
  finda.cliApp -> finda.analyticsService 'requests exported reports on completion'

}
